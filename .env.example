# --- Telegram ---
# Создаётся через @BotFather. Не забудь у BotFather: /setprivacy → Disable
# (иначе бот в группе будет видеть только свои упоминания).
TELEGRAM_BOT_TOKEN=

# Численный chat_id рабочей супергруппы (для супергрупп с форумом — отрицательный, начинается с -100...).
# Узнать: добавь бота, отправь любое сообщение, посмотри в логах bot или https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# message_thread_id forum-топика, в который бот будет постить дневные батчи и задавать
# вопросы команде. Создай в супергруппе forum-топик "DuckSidian", скопируй id из ссылки на топик.
TELEGRAM_TOPIC_ID=

# Список user_id админов через запятую — кто может вызывать /lint, /pause, /resume, /ingest force.
TELEGRAM_ADMINS=

# --- Мультичат (опционально) ---
# Формат: "chat_id:name[:topic_id]|chat_id:name[:topic_id]|..."
# Пример: "-10012345678:main:456|-10087654321:sales:"
# Если пусто — используется TELEGRAM_CHAT_ID + TELEGRAM_TOPIC_ID как единственный чат.
# Имя (name) = слаг поддиректории vault: vault/main/, vault/sales/ и т.д.
TELEGRAM_CHATS=

# --- DeepSeek (OpenAI-compatible) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Расписание ingest (cron, TZ из переменной TZ) ---
# По умолчанию 23:00 каждый день.
INGEST_CRON=0 23 * * *
TZ=Europe/Moscow

# --- Obsidian web (KasmVNC) ---
OBSIDIAN_USER=admin
OBSIDIAN_PASSWORD=changeme
OBSIDIAN_PORT=3000

# --- Git auto-sync (опционально) ---
# Если задан — vault будет коммитить и пушить после каждого ingest/lint.
GIT_AUTOCOMMIT=true
GIT_REMOTE_URL=
GIT_USER_NAME=DuckSidian Bot
GIT_USER_EMAIL=ducksidian@localhost
